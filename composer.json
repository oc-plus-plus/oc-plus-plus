{
  "name": "opencart-fixes/oc4",
  "description": "OpenCart",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "opencart",
    "ecommerce",
    "framework",
    "opensource"
  ],
  "homepage": "https://www.opencart.com/",
  "support": {
    "issues": "https://github.com/opencart/opencart/issues",
    "forum": "https://forum.opencart.com/",
    "wiki": "https://github.com/opencart/opencart/wiki",
    "docs": "http://docs.opencart.com/"
  },
  "config": {
    "optimize-autoloader": true,
    "vendor-dir": "www/system/storage/vendor/"
  },
  "require": {
    "php": ">=8.1",
    "scssphp/scssphp": "^2.1",
    "twig/twig": "^3.24"
  },
  "autoload-dev": {
    "psr-4": {
      "Tools\\PHPStan\\": "tools/phpstan/"
    }
  },
  "scripts": {
    "static-analysis": "php tools/phpstan.phar analyze"
  }
}
